{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role information.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Place": {
      "title": "Place",
      "description": "A restaurant or shop registered on the map.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["restaurant", "shop", "other"] },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "country": { "type": "string" },
        "prefecture": { "type": "string" },
        "municipality": { "type": "string" },
        "address": { "type": "string" },
        "websiteUrl": { "type": "string", "format": "uri" },
        "uid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "lat", "lng", "uid", "createdAt"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "A user's favorite place.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "placeId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "placeId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/admin_places/{placeId}": {
      "schema": "Place",
      "description": "Places managed by admins"
    },
    "/favorites/{favoriteId}": {
      "schema": "Favorite",
      "description": "User favorites"
    }
  }
}
